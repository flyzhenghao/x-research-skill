[core]
	repositoryformatversion = 1
	filemode = true
	bare = false
	logallrefupdates = true
	ignorecase = true
	precomposeunicode = true
[remote "upstream"]
	url = https://github.com/xBenJamminx/x-research-skill.git
	promisor = true
	partialclonefilter = blob:none
	fetch = +refs/heads/main:refs/remotes/upstream/main
[branch "main"]
	remote = upstream
	merge = refs/heads/main
[extensions]
	worktreeConfig = true
[remote "origin"]
	url = https://github.com/flyzhenghao/x-research-skill.git
	fetch = +refs/heads/*:refs/remotes/origin/*
